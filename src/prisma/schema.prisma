generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                     String                  @id @default(cuid())
  name                   String
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  deletedAt              DateTime?
  auditLogs              AuditLog[]
  conversations          Conversation[]
  integrationConnections IntegrationConnection[]
  projects               Project[]
  users                  User[]
  projectInvites         ProjectInvite[]
  meetings               Meeting[]
}

model User {
  id                   String               @id @default(cuid())
  organizationId       String
  email                String               @unique
  passwordHash         String
  name                 String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  avatarUrl            String?
  deletedAt            DateTime?
  globalRole           GlobalRole           @default(ADMIN)
  apiKeys              ApiKey[]
  attendees            Attendee[]
  auditLogs            AuditLog[]
  conversationsCreated Conversation[]       @relation("ConversationCreatedBy")
  messages             Message[]
  passwordResetTokens  PasswordResetToken[]
  createdProjects      Project[]            @relation("ProjectCreatedBy")
  projectMemberships   ProjectMember[]
  assignedTasks        ProjectTask[]        @relation("TaskAssignee")
  refreshTokens        RefreshToken[]
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProjectInvite {
  id             String       @id @default(cuid())
  organizationId String
  projectId      String?
  email          String
  projectRole    ProjectRole?
  tokenHash      String       @unique
  expiresAt      DateTime
  status         InviteStatus @default(PENDING)
  createdAt      DateTime     @default(now())

  project        Project?     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([organizationId])
  @@unique([organizationId, projectId, email], name: "org_project_email")
}

model Meeting {
  id               String              @id @default(cuid())
  organizationId   String
  title            String
  agenda           String?
  scheduledTime    DateTime
  status           String              @default("scheduled")
  meetingLink      String?
  botStatus        String?
  transcriptStatus String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deletedAt        DateTime?
  projectId        String?
  extractionJson   Json?
  rawTranscript    String?             @db.LongText
  actionItems      ActionItem[]
  attendees        Attendee[]
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project          Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks            ProjectTask[]
  transcript       TranscriptSegment[]

  @@index([organizationId])
  @@index([projectId])
}

model Attendee {
  id        String  @id @default(cuid())
  meetingId String
  name      String
  email     String
  joined    Boolean @default(false)
  isBot     Boolean @default(false)
  userId    String?
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user      User?   @relation(fields: [userId], references: [id])

  @@index([meetingId])
  @@index([userId])
}

model TranscriptSegment {
  id        String  @id @default(cuid())
  meetingId String
  speaker   String
  timestamp Int
  text      String  @db.Text
  meeting   Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model ActionItem {
  id        String    @id @default(cuid())
  meetingId String
  text      String    @db.Text
  assignee  String?
  dueDate   DateTime?
  meeting   Meeting   @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
}

model Project {
  id             String             @id @default(cuid())
  organizationId String
  name           String
  client         String?
  progress       Int                @default(0)
  health         String?
  status         String?
  dueDate        DateTime?
  asanaLink      String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  clientName     String?
  createdById    String?
  budgetTotal    Decimal            @default(0.00) @db.Decimal(12, 2)
  apiKeys        ApiKey[]
  meetings       Meeting[]
  createdBy      User?              @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  organization   Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expenses       ProjectExpense[]
  invites        ProjectInvite[]
  members        ProjectMember[]
  milestones     ProjectMilestone[]
  risks          ProjectRisk[]
  tasks          ProjectTask[]

  @@index([organizationId])
  @@index([createdById])
}

model ProjectMember {
  id          String      @id @default(cuid())
  userId      String
  projectId   String
  projectRole ProjectRole
  joinedAt    DateTime    @default(now())
  project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([projectId])
  @@index([userId])
}

model ProjectMilestone {
  id        String    @id @default(cuid())
  projectId String
  title     String
  dueDate   DateTime?
  status    String    @default("Not Started")
  progress  Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectRisk {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?  @db.Text
  severity    String   @default("medium")
  status      String   @default("Active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectTask {
  id             String       @id @default(cuid())
  projectId      String
  title          String
  status         TaskStatus   @default(NOT_STARTED)
  dueDate        DateTime?
  assigneeUserId String?
  description    String?      @db.Text
  priority       TaskPriority @default(MEDIUM)
  meetingId      String?
  assignee       User?        @relation("TaskAssignee", fields: [assigneeUserId], references: [id])
  meeting        Meeting?     @relation(fields: [meetingId], references: [id])
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, title])
  @@index([projectId])
  @@index([meetingId])
  @@index([assigneeUserId])
}

model ProjectExpense {
  id          String    @id @default(cuid())
  projectId   String
  amount      Decimal   @db.Decimal(12, 2)
  description String?
  category    String?
  incurredAt  DateTime?
  createdAt   DateTime  @default(now())
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Conversation {
  id             String       @id @default(cuid())
  organizationId String
  createdById    String
  createdAt      DateTime     @default(now())
  createdBy      User         @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@index([organizationId])
  @@index([createdById])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  userId         String?
  role           String
  content        String       @db.LongText
  meetingId      String?
  meetingTitle   String?
  timestamp      Int?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([conversationId])
  @@index([userId])
}

model Integration {
  id          String                  @id @default(cuid())
  name        String
  createdAt   DateTime                @default(now())
  connections IntegrationConnection[]
}

model IntegrationConnection {
  id             String       @id @default(cuid())
  organizationId String
  integrationId  String
  status         String       @default("disconnected")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  integration    Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, integrationId])
  @@index([organizationId])
  @@index([integrationId])
}

model WebhookEvent {
  id         String   @id @default(cuid())
  type       String
  signature  String
  payload    String   @db.LongText
  receivedAt DateTime @default(now())
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String?
  action         String
  meta           String?      @db.LongText
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
}

model ApiKey {
  id        String    @id @default(cuid())
  name      String
  keyHash   String    @unique
  userId    String
  projectId String
  createdAt DateTime  @default(now())
  lastUsed  DateTime?
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

enum GlobalRole {
  SUPER_ADMIN
  ADMIN
  TEAM_MEMBER
}

enum ProjectRole {
  ADMIN
  PROJECT_MANAGER
  CONTRIBUTOR
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}
